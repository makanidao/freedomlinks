# ─────────────────────────────────────────────────────────────────────────────
# FreedomLinks — environment variables
#
# Copy this file to `.env.local` for local development, and add the same values
# to your Vercel project settings for production. NEVER commit real keys.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# Your Stripe SECRET key (server-side only — keep this private).
# Test mode starts with sk_test_..., live mode with sk_live_...
# Find it at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_secret_key_here

# Your Stripe PUBLISHABLE key (safe to expose to the browser).
# Test mode starts with pk_test_..., live mode with pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key_here

# Webhook signing secret used to verify Stripe webhook events.
# Local: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#        and copy the "whsec_..." it prints.
# Prod:  create a webhook endpoint in the Stripe Dashboard pointing to
#        https://your-domain.com/api/webhooks/stripe and copy its signing secret.
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# Stripe Price IDs — one per vendor. Create a Product + Price for each in the
# Stripe Dashboard (Products → Add product), then paste each Price ID here.
# Price IDs look like: price_1Q...
STRIPE_PRICE_SM7B=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CHROME_HEARTS=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SURRON=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_COLOGNE=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_DYSON=price_xxxxxxxxxxxxxxxxxxxxxxxx
# Sp5der Vendor — authentic Sp5der sourcing list.
STRIPE_PRICE_SP5DER=price_xxxxxxxxxxxxxxxxxxxxxxxx
# AirPods Max Vendor — authentic AirPods Max sourcing list.
STRIPE_PRICE_AIRPODS_MAX=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL of the site. Used to build Stripe success/cancel URLs and
# canonical/OG metadata. Leave unset locally to auto-detect from the request.
# Production example: https://freedomlinks.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
